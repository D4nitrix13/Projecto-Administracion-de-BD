DB_HOST=pandas_bd
DB_PORT=5432
DB_DATABASE=pandas_estampados_y_kitsune
DB_USERNAME=postgres
DB_PASSWORD=root
APP_TIMEZONE=America/Managua
APP_ENV=development

# Password Recovery
RESET_PASSWORD_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_MIN_32_CHARS
RESET_PASSWORD_EXPIRES_MINUTES=30

# SMTP Configuration (for sending password recovery emails)
# Default: MailPit (Docker) — captures all emails at http://localhost:8025
# For production, replace with your real SMTP credentials
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pandakitsune.com
SMTP_FROM_NAME=Panda Estampados y Kitsune
